# ─────────────────────────────────────────────
# Chronos-CMS — Environment Variables Example
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Full Postgres connection string used by Prisma
DATABASE_URL="postgresql://chrono:secret@localhost:5432/chronos_cms?schema=public"

# ── API ───────────────────────────────────────
# Port the Fastify API server listens on
API_PORT=4000

# Secret used to sign JWT tokens — use a strong random string in production
JWT_SECRET="change_me_to_a_long_random_secret"

# Token expiry (e.g. 7d, 1h, 30m)
JWT_EXPIRES_IN="7d"

# Origin(s) allowed for CORS (comma-separated). Use * for dev convenience.
CORS_ORIGIN="http://localhost:5173"

# ── Web (Vite) ────────────────────────────────
# URL of the API server as seen from the browser
VITE_API_URL="http://localhost:4000"

# ── Seeding ───────────────────────────────────
# Credentials for the default admin account created by the seed script
ADMIN_EMAIL="admin@chronos.dev"
ADMIN_PASSWORD="Admin1234!"
