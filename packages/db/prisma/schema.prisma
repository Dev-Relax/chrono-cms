// ─────────────────────────────────────────────────────────────────────────────
// Chronos-CMS — Prisma Schema (i18n edition)
// Docs: https://www.prisma.io/docs/concepts/components/prisma-schema
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum Role {
  ADMIN
  EDITOR
  AUTHOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
  REJECTED
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

enum SubmissionStatus {
  NEW
  READ
  ARCHIVED
}

// ── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  /// bcrypt-hashed password — never expose in API responses
  password  String
  name      String?
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts         Post[]
  pages         Page[]
  projects      Project[]
  apiKeys       ApiKey[]
  postRevisions PostRevision[]
  activityLogs  ActivityLog[]

  @@map("users")
}

// ── Tag ──────────────────────────────────────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  posts PostTag[]

  @@map("tags")
}

// ── Post ─────────────────────────────────────────────────────────────────────
// Container for global, locale-agnostic metadata.
// All translatable content (title, slug, body) lives in PostTranslation.

model Post {
  id            String     @id @default(cuid())
  /// BCP-47 locale tag of the canonical version (e.g. "en", "fr")
  defaultLocale String     @default("en")
  status        PostStatus @default(DRAFT)
  featured      Boolean    @default(false)
  publishedAt   DateTime?
  scheduledAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  translations   PostTranslation[]
  tags           PostTag[]
  revisions      PostRevision[]
  comments       Comment[]
  linkedProjects Project[]         @relation("PostProjects")

  @@index([status])
  @@index([status, publishedAt(sort: Desc)])
  @@index([featured])
  @@index([authorId])
  @@index([scheduledAt])
  @@map("posts")
}

// ── PostTranslation ───────────────────────────────────────────────────────────
// Per-locale translatable content for a Post.
// Unique slug per locale enables /en/my-post vs /fr/mon-article routing.

model PostTranslation {
  id    String @id @default(cuid())
  postId String
  /// BCP-47 locale tag (e.g. "en", "fr", "es")
  locale String

  title   String
  slug    String
  /// TipTap ProseMirror document stored as raw JSON
  content Json   @default("{}")
  /// Plain-text excerpt (optional)
  excerpt String?

  /// SEO overrides — falls back to title/excerpt when blank
  metaTitle       String?
  metaDescription String?
  /// URL of the Open Graph / social share image
  ogImage         String?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  /// One translation per locale per post
  @@unique([postId, locale])
  /// Slugs must be unique within a locale
  @@unique([locale, slug])
  @@index([slug])
  @@index([locale])
  @@map("post_translations")
}

// ── Page ─────────────────────────────────────────────────────────────────────
// Standalone CMS pages (About, Contact, etc.) — no tags, no scheduling.
// All translatable content (title, slug, body) lives in PageTranslation.

model Page {
  id            String     @id @default(cuid())
  /// BCP-47 locale tag of the canonical version (e.g. "en", "fr")
  defaultLocale String     @default("en")
  status        PageStatus @default(DRAFT)
  /// Layout + display settings: { layout, showToc, showHero }
  pageConfig    Json       @default("{}")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  translations PageTranslation[]

  @@index([status])
  @@map("pages")
}

// ── PageTranslation ───────────────────────────────────────────────────────────
// Per-locale translatable content for a Page.

model PageTranslation {
  id     String @id @default(cuid())
  pageId String
  /// BCP-47 locale tag (e.g. "en", "fr", "es")
  locale String

  title           String
  slug            String
  /// TipTap ProseMirror document stored as raw JSON
  content         Json    @default("{}")
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  /// Per-locale hero: { subtitle, image, ctaText, ctaUrl }
  heroContent     Json?

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  /// One translation per locale per page
  @@unique([pageId, locale])
  /// Slugs must be unique within a locale
  @@unique([locale, slug])
  @@index([slug])
  @@index([locale])
  @@map("page_translations")
}

// ── Project ──────────────────────────────────────────────────────────────────
// Portfolio / showcase items — locale-agnostic metadata lives here, all
// translatable content (title, slug, summary, body) lives in ProjectTranslation.

model Project {
  id            String        @id @default(cuid())
  /// BCP-47 locale tag of the canonical version (e.g. "en", "fr")
  defaultLocale String        @default("en")
  status        ProjectStatus @default(DRAFT)
  featured      Boolean       @default(false)
  /// Manual portfolio ordering (lower = earlier)
  order         Int           @default(0)
  /// /uploads/… path or absolute URL
  coverImage    String?
  /// Tech-stack chips, locale-agnostic (cf. Webhook.events)
  techStack     String[]
  githubUrl     String?
  liveUrl       String?
  /// External article URL (used when postId is null)
  blogUrl       String?
  /// Internal post link — resolved to /posts/:slug at read time
  postId        String?
  post          Post?         @relation("PostProjects", fields: [postId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  translations ProjectTranslation[]

  @@index([status])
  @@index([status, order])
  @@index([featured])
  @@index([authorId])
  @@map("projects")
}

// ── ProjectTranslation ─────────────────────────────────────────────────────────
// Per-locale translatable content for a Project.

model ProjectTranslation {
  id        String @id @default(cuid())
  projectId String
  /// BCP-47 locale tag (e.g. "en", "fr", "es")
  locale    String

  title   String
  slug    String
  /// Plain-text card blurb (optional)
  summary String?
  /// Optional TipTap ProseMirror long description stored as raw JSON
  content Json    @default("{}")

  metaTitle       String?
  metaDescription String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// One translation per locale per project
  @@unique([projectId, locale])
  /// Slugs must be unique within a locale
  @@unique([locale, slug])
  @@index([slug])
  @@index([locale])
  @@map("project_translations")
}

// ── SiteSettings (singleton) ─────────────────────────────────────────────────

model SiteSettings {
  id          String   @id @default("singleton")
  themeConfig Json     @default("{}")
  brandConfig Json     @default("{}")
  navConfig   Json     @default("{}")
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

// ── PostTag (join table) ──────────────────────────────────────────────────────

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// ── Webhook ───────────────────────────────────────────────────────────────────
// Outbound HTTP callbacks fired on CMS events.

model Webhook {
  id        String   @id @default(cuid())
  name      String
  url       String
  /// Optional HMAC-SHA256 signing secret — sent as X-Webhook-Signature header
  secret    String?
  /// Array of event names this webhook listens to. Empty = all events.
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhooks")
}

// ── ApiKey ────────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  prefix     String
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyHash])
  @@map("api_keys")
}

// ── PostRevision ──────────────────────────────────────────────────────────────
// Per-locale snapshot of a translation saved on every PUT.
// Latest 10 revisions per post+locale are kept; older ones are pruned.

model PostRevision {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// The locale this revision belongs to
  locale String @default("en")
  title  String
  content Json

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([postId, locale])
  @@map("post_revisions")
}

// ── Comment ───────────────────────────────────────────────────────────────────

model Comment {
  id          String        @id @default(cuid())
  content     String
  authorName  String
  authorEmail String
  status      CommentStatus @default(PENDING)

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([status])
  @@index([parentId])
  @@map("comments")
}

// ── Testimonial ───────────────────────────────────────────────────────────────

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  role      String?
  company   String?
  avatarUrl String?
  content   String
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  visible   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, featured])
  @@index([order])
  @@map("testimonials")
}

// ── Education ─────────────────────────────────────────────────────────────────

model Education {
  id           String                 @id @default(cuid())
  institution  String
  field        String?
  startDate    DateTime
  endDate      DateTime?
  url          String?
  logoUrl      String?
  order        Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  translations EducationTranslation[]

  @@index([order])
  @@map("education")
}

model EducationTranslation {
  id          String    @id @default(cuid())
  educationId String
  locale      String
  degree      String
  description Json      @default("{}")
  education   Education @relation(fields: [educationId], references: [id], onDelete: Cascade)

  @@unique([educationId, locale])
  @@index([locale])
  @@map("education_translations")
}

// ── Experience ────────────────────────────────────────────────────────────────

model Experience {
  id           String                  @id @default(cuid())
  company      String
  location     String?
  startDate    DateTime
  endDate      DateTime?
  url          String?
  logoUrl      String?
  order        Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  translations ExperienceTranslation[]

  @@index([order])
  @@map("experiences")
}

model ExperienceTranslation {
  id           String     @id @default(cuid())
  experienceId String
  locale       String
  role         String
  description  Json       @default("{}")
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([experienceId, locale])
  @@index([locale])
  @@map("experience_translations")
}

// ── Skill ─────────────────────────────────────────────────────────────────────

model Skill {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  category  String
  level     SkillLevel @default(INTERMEDIATE)
  icon      String?
  order     Int        @default(0)
  visible   Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([category])
  @@index([order])
  @@map("skills")
}

// ── Certification ─────────────────────────────────────────────────────────────

model Certification {
  id            String    @id @default(cuid())
  /// Canonical/fallback title — kept for backward compat; translations take precedence
  title         String
  issuer        String
  issuedAt      DateTime
  expiresAt     DateTime?
  credentialUrl String?
  logoUrl       String?
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  translations CertificationTranslation[]

  @@index([order])
  @@map("certifications")
}

// ── CertificationTranslation ──────────────────────────────────────────────────

model CertificationTranslation {
  id              String        @id @default(cuid())
  certificationId String
  locale          String
  title           String
  /// Optional TipTap ProseMirror document stored as raw JSON
  description     Json          @default("{}")

  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([certificationId, locale])
  @@index([locale])
  @@map("certification_translations")
}

// ── ContactSubmission ─────────────────────────────────────────────────────────

model ContactSubmission {
  id        String           @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("contact_submissions")
}

// ── AnalyticsPageView ─────────────────────────────────────────────────────────
// Written by the portfolio frontend on every route change. No PII — IP is not
// stored; sessionId is a random UUID generated in sessionStorage.

model AnalyticsPageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  locale    String?
  device    String?
  sessionId String
  /// Optional link to a post (set by the tracker when visiting /blog/:slug)
  postId    String?
  /// Optional link to a project (set by the tracker when visiting /projects/:slug)
  projectId String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([postId])
  @@index([projectId])
  @@map("analytics_page_views")
}

// ── AnalyticsEvent ────────────────────────────────────────────────────────────
// Custom events: outbound link clicks, read completions, etc.

model AnalyticsEvent {
  id        String   @id @default(cuid())
  /// "outbound_click" | "read_complete" | "project_click" | "contact_open"
  type      String
  path      String
  /// URL for clicks, post slug for reads
  target    String?
  sessionId String
  createdAt DateTime @default(now())

  @@index([type])
  @@index([path])
  @@index([createdAt(sort: Desc)])
  @@index([sessionId])
  @@map("analytics_events")
}

// ── ActivityLog ───────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  entityType  String
  entityId    String?
  entityTitle String?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("activity_logs")
}
